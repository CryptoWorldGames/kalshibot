# Kalshi Bot — Local Secrets (NEVER commit to git)
# Copy this file to ".env" and fill in your own values.
#
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env

# Kalshi API credentials — get yours from https://kalshi.com/account/api
KALSHI_API_KEY=
KALSHI_EMAIL=

# Your timezone (used for trade timestamps / scheduling)
BOT_TIMEZONE=America/Chicago
